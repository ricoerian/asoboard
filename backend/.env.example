# ================================================
# AsoBoard Environment Configuration
# ================================================
# Copy this file to .env and update with your values
# NEVER commit .env to git!

# ================================================
# Django Settings
# ================================================

# Generate new secret key with:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-generate-a-new-one-CHANGE-THIS

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx_backend

# ================================================
# Database Configuration (PostgreSQL)
# ================================================

DB_ENGINE=django.db.backends.postgresql
DB_NAME=asoboard
DB_USER=asoboard_user
DB_PASSWORD=changeme_secure_password_here
DB_HOST=db
DB_PORT=5432

# ================================================
# PostgreSQL Settings (for Docker)
# ================================================

POSTGRES_DB=asoboard
POSTGRES_USER=asoboard_user
POSTGRES_PASSWORD=changeme_secure_password_here

# ================================================
# Redis Configuration
# ================================================

REDIS_HOST=redis
REDIS_PORT=6379

# ================================================
# CORS Settings
# ================================================

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8000

# ================================================
# JWT Settings
# ================================================

JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ================================================
# Gunicorn Settings
# ================================================

# Number of worker processes (recommended: 2 * CPU cores + 1)
GUNICORN_WORKERS=4

# ================================================
# Development Settings
# ================================================

# For local development without Docker, use SQLite:
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
# (and comment out DB_USER, DB_PASSWORD, DB_HOST, DB_PORT)